{
  "name": "minecraft-launcher",
  "version": "1.0.0",
  "description": "Minecraft launcher with ely.by authentication for cracked players",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run build:main && concurrently --kill-others \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json && copy /Y \"src\\images\\logo.png\" \"dist\\icon.png\"",
    "build": "npm run build:renderer && npm run build:main",
    "start": "npm run build && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.launcher.minecraft",
    "productName": "Asterid Launcher",
    "files": [
      "dist/**/*",
      "!dist/renderer/src"
    ],
    "extraResources": [
      {
        "from": "runtime",
        "to": "runtime"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "uuid": "^9.0.0"
  }
}
